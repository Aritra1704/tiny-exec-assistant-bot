# Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=put_your_token_here

# Ollama endpoint and models
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CREATIVE_MODEL=
CREATIVE_INTENT_ROUTING=true

# Retrieval and embedding settings
RAG_TOP_K=5
EMBED_MAX_CHARS=2000
CHAT_CONTEXT_CHAR_LIMIT=1200

# Postgres connection and schema
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=postgres
PG_USER=postgres
PG_PASSWORD=
PG_SCHEMA=tinyse

# Logging
LOG_LEVEL=INFO
